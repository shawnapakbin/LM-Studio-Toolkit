# Example environment variables for LLM Toolkit
# Copy to .env and fill in your actual values

# --- Browserless MCP Integration ---
BROWSERLESS_TOKEN=your-browserless-api-token-here
# BROWSERLESS_API_URL=               # Custom Browserless API URL. Empty defaults to https://production-sfo.browserless.io

# --- Blender MCP Integration ---
# BLENDER_MCP_HOST=127.0.0.1        # Blender add-on TCP host (default: 127.0.0.1)
# BLENDER_MCP_PORT=9876              # Blender add-on TCP port (default: 9876, range: 1-65535)
# BLENDER_MCP_COMMAND=blender-mcp    # MCP server binary command (default: blender-mcp)
# BLENDER_MCP_ARGS=                  # MCP server arguments, whitespace-separated (default: empty, max: 1024 chars)
