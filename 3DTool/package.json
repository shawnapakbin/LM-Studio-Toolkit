{
  "name": "llm-toolkit-3dtool",
  "version": "2.3.0",
  "description": "3D model viewer and editor MCP server with multi-format support",
  "main": "dist/mcp-server.js",
  "types": "dist/mcp-server.d.ts",
  "scripts": {
    "build": "node --max-old-space-size=8192 ../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js",
    "clean": "node -e \"const fs=require('fs');const path=require('path');const dist='dist';fs.readdirSync(dist).filter(f=>f!=='viewer').forEach(f=>fs.rmSync(path.join(dist,f),{recursive:true,force:true}))\""
  },
  "keywords": ["3d", "viewer", "mcp", "model-context-protocol", "gltf", "obj"],
  "author": "Shawna Pakbin",
  "license": "LicenseRef-Shawna-NonCommercial",
  "dependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/three": "^0.172.0"
  }
}
